{
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/cashflow",
    "Audience": "cashflow-api"
  },
  "ReverseProxy": {
    "Routes": {
      "transaction-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/transactions/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "transaction-cluster": {
        "Destinations": {
          "transaction-api": {
            "Address": "http://transaction-api:8080/"
          }
        }
      }
    }
  },
  "Routes": {
    "transaction-route": {
      "ClusterId": "transaction-cluster",
      "Match": {
        "Path": "/transactions/{**catch-all}"
      },
      "AuthorizationPolicy": "default"
    }
  }
}