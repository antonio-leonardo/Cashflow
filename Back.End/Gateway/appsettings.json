{
  "Providers": {
    "Messaging": "RabbitMq",
    "Identity": "Keycloak",
    "Telemetry": "Jaeger"
  },
  "EntraId": {
    "TenantId": "",
    "ClientId": "",
    "Audience": "api://cashflow-api"
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/cashflow",
    "Audience": "cashflow-api"
  },
  "DownstreamHealthChecks": {
    "TimeoutSeconds": 2
  },
  "Resilience": {
    "Downstreams": {
      "TransactionReadiness": {
        "RetryCount": 2,
        "RetryBaseDelayMilliseconds": 200,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerBreakSeconds": 15,
        "BulkheadParallelization": 20,
        "BulkheadQueue": 60,
        "TimeoutSeconds": 3,
        "EnableFallback": false
      },
      "BalanceReadiness": {
        "RetryCount": 2,
        "RetryBaseDelayMilliseconds": 200,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerBreakSeconds": 15,
        "BulkheadParallelization": 20,
        "BulkheadQueue": 60,
        "TimeoutSeconds": 3,
        "EnableFallback": false
      }
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 1,
      "QueueLimit": 50
    },
    "Policies": {
      "TransactionWrite": {
        "PermitLimit": 40,
        "WindowSeconds": 1,
        "QueueLimit": 20
      },
      "TransactionRead": {
        "PermitLimit": 120,
        "WindowSeconds": 1,
        "QueueLimit": 40
      },
      "BalanceRead": {
        "PermitLimit": 150,
        "WindowSeconds": 1,
        "QueueLimit": 60
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "transaction-write-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/api/transactions/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "AuthorizationPolicy": "TransactionsWrite",
        "RateLimiterPolicy": "gateway-transaction-write"
      },
      "transaction-read-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/api/transactions/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy": "gateway-transaction-read"
      },
      "balance-daily-read-route": {
        "ClusterId": "balance-query-cluster",
        "Match": {
          "Path": "/api/balance/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy": "gateway-balance-read"
      },
      "transaction-v1-write-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/api/v1/transactions/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "AuthorizationPolicy": "TransactionsWrite",
        "RateLimiterPolicy": "gateway-transaction-write"
      },
      "transaction-v1-read-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/api/v1/transactions/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy": "gateway-transaction-read"
      },
      "balance-v1-read-route": {
        "ClusterId": "balance-query-cluster",
        "Match": {
          "Path": "/api/v1/balance/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy": "gateway-balance-read"
      }
    },
    "Clusters": {
      "transaction-cluster": {
        "Destinations": {
          "transaction-api": {
            "Address": "http://transaction-api:8080/"
          }
        }
      },
      "balance-query-cluster": {
        "Destinations": {
          "balance-query-api": {
            "Address": "http://balance-query-api:8080/"
          }
        }
      }
    }
  }
}
