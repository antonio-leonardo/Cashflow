{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "Connection": "localhost:6379"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/cashflow",
    "Audience": "cashflow-api"
  },
  "RateLimiting": {
    "PermitLimit": 150,
    "WindowSeconds": 1,
    "QueueLimit": 75
  }
}
